# Firebase Configuration
# For local development with emulators, use any placeholder values below.
# For staging/production, get real values from Firebase Console:
#   Project Settings → General → Your apps → Web app → Config
EXPO_PUBLIC_FIREBASE_API_KEY=demo-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-dungeon-scribe.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=demo-dungeon-scribe
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-dungeon-scribe.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:demo

# Google OAuth Client IDs (from Google Cloud Console → APIs & Services → Credentials)
# Required for Google Sign-In. Leave empty for local dev (email/password works without these).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Environment (development | staging | production)
APP_ENV=development
